# .env.example
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# 32-byte raw string, 64-char hex, or base64 that decodes to 32 bytes
MEMORY_TEXT_ENCRYPTION_KEY=replace-with-memory-text-encryption-key

# log level (DEBUG | INFO | WARNING | ERROR | CRITICAL), default: INFO
# Next.js (NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_LOG_LEVEL=warning

# service/
# log level (DEBUG | INFO | WARNING | ERROR | CRITICAL), default: INFO
LOG_LEVEL=WARNING
